<div id="app" data-order-id="<%= orderId %>" data-payment-result="<%= paymentResult %>">
  <h1 class="text-2xl font-bold text-text-primary mb-6" style="font-family: 'Noto Serif TC', serif;">訂單詳情</h1>

  <div v-if="loading" class="flex justify-center py-12">
    <div class="w-8 h-8 border-4 border-rose-primary border-t-transparent rounded-full animate-spin"></div>
  </div>

  <template v-else-if="order">
    <!-- Payment Result Alert -->
    <div
      v-if="paymentResult && paymentMessages[paymentResult]"
      class="rounded-xl p-4 mb-6 text-sm"
      :class="paymentMessages[paymentResult].cls"
    >
      {{ paymentMessages[paymentResult].text }}
    </div>

    <!-- Order Info -->
    <div class="bg-white rounded-2xl shadow-sm p-6 mb-6">
      <div class="flex items-start justify-between">
        <div>
          <p class="text-sm text-text-secondary">訂單編號：{{ order.order_no }}</p>
          <p class="text-xs text-text-muted mt-1">建立日期：{{ new Date(order.created_at).toLocaleDateString('zh-TW') }}</p>
        </div>
        <span
          class="text-xs px-3 py-1 rounded-full font-medium"
          :class="statusMap[order.status]?.cls || 'bg-gray-100 text-gray-600'"
        >
          {{ statusMap[order.status]?.label || order.status }}
        </span>
      </div>
    </div>

    <!-- Recipient Info -->
    <div class="bg-white rounded-2xl shadow-sm p-6 mb-6">
      <h2 class="font-medium text-text-primary mb-3">收件資訊</h2>
      <div class="text-sm space-y-2 text-text-secondary">
        <p>收件人：{{ order.recipient_name }}</p>
        <p>Email：{{ order.recipient_email }}</p>
        <p>地址：{{ order.recipient_address }}</p>
      </div>
    </div>

    <!-- Order Items -->
    <div class="bg-white rounded-2xl shadow-sm p-6 mb-6">
      <h2 class="font-medium text-text-primary mb-3">商品明細</h2>
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-gray-100 text-text-muted">
            <th class="text-left py-2 font-normal">商品名稱</th>
            <th class="text-right py-2 font-normal">單價</th>
            <th class="text-right py-2 font-normal">數量</th>
            <th class="text-right py-2 font-normal">小計</th>
          </tr>
        </thead>
        <tbody>
          <tr v-for="item in order.items" :key="item.id" class="border-b border-gray-50">
            <td class="py-3 text-text-primary">{{ item.product_name }}</td>
            <td class="py-3 text-right text-text-secondary">NT$ {{ item.product_price.toLocaleString() }}</td>
            <td class="py-3 text-right text-text-secondary">{{ item.quantity }}</td>
            <td class="py-3 text-right text-text-primary font-medium">NT$ {{ (item.product_price * item.quantity).toLocaleString() }}</td>
          </tr>
        </tbody>
        <tfoot>
          <tr>
            <td colspan="3" class="pt-3 text-right font-bold text-text-primary">總計</td>
            <td class="pt-3 text-right font-bold text-rose-primary text-lg">NT$ {{ order.total_amount.toLocaleString() }}</td>
          </tr>
        </tfoot>
      </table>
    </div>

    <!-- ATM 繳費資訊 -->
    <div v-if="hasAtmInfo" class="bg-white rounded-2xl shadow-sm p-6 mb-6 border border-apricot/30">
      <h2 class="font-medium text-text-primary mb-3">ATM 繳費資訊</h2>
      <div class="text-sm space-y-2 text-text-secondary">
        <p>銀行代碼：<span class="font-mono font-bold text-text-primary">{{ order.payment_info_bank_code }}</span></p>
        <p>虛擬帳號：<span class="font-mono font-bold text-text-primary tracking-widest">{{ order.payment_info_vaccount }}</span></p>
        <p v-if="order.payment_info_expire_date">繳費期限：{{ order.payment_info_expire_date }}</p>
      </div>
      <p class="text-xs text-text-muted mt-3">請至 ATM 輸入上方銀行代碼與帳號完成轉帳，付款完成後系統將自動更新狀態。</p>
    </div>

    <!-- CVS 繳費資訊 -->
    <div v-if="hasCvsInfo" class="bg-white rounded-2xl shadow-sm p-6 mb-6 border border-apricot/30">
      <h2 class="font-medium text-text-primary mb-3">超商繳費資訊</h2>
      <div class="text-sm space-y-2 text-text-secondary">
        <p>繳費代碼：<span class="font-mono font-bold text-text-primary tracking-widest">{{ order.payment_info_payment_no }}</span></p>
        <p v-if="order.payment_info_expire_date">繳費期限：{{ order.payment_info_expire_date }}</p>
      </div>
      <p class="text-xs text-text-muted mt-3">請至 7-11（ibon）、全家、萊爾富或 OK mart 輸入上方代碼完成繳費，付款完成後系統將自動更新狀態。</p>
    </div>

    <!-- Payment Section -->
    <div v-if="order.status === 'pending'" class="bg-white rounded-2xl shadow-sm p-6">
      <h2 class="font-medium text-text-primary mb-4">付款</h2>

      <!-- 付款方式選擇 -->
      <div class="mb-4">
        <p class="text-sm text-text-secondary mb-2">選擇付款方式</p>
        <div class="flex flex-wrap gap-2">
          <label
            v-for="m in paymentMethods"
            :key="m.value"
            class="flex items-center gap-2 cursor-pointer px-4 py-2 rounded-full border text-sm transition-colors"
            :class="selectedPaymentMethod === m.value
              ? 'border-rose-primary bg-rose-primary/5 text-rose-primary font-medium'
              : 'border-gray-200 text-text-secondary hover:border-rose-primary/40'"
          >
            <input type="radio" :value="m.value" v-model="selectedPaymentMethod" class="sr-only" />
            {{ m.label }}
          </label>
        </div>
        <p v-if="selectedPaymentMethod === 'ATM'" class="text-xs text-text-muted mt-2">
          取號後請至 ATM 轉帳，繳費期限 7 天，完成後系統將自動確認。
        </p>
        <p v-if="selectedPaymentMethod === 'CVS'" class="text-xs text-text-muted mt-2">
          取號後請至超商輸入代碼繳費，繳費期限 3 天，完成後系統將自動確認。
        </p>
      </div>

      <div class="flex flex-wrap gap-3">
        <button
          @click="goToEcpay"
          :disabled="paying"
          class="bg-rose-primary text-white px-8 py-3 rounded-full text-sm font-medium hover:bg-rose-dark transition-colors disabled:opacity-50"
        >
          {{ paying ? '處理中...' : (selectedPaymentMethod === 'Credit' ? '前往綠界付款' : '取得繳費資訊') }}
        </button>
        <button
          @click="requeryPayment"
          :disabled="paying"
          class="bg-white border border-rose-primary text-rose-primary px-6 py-3 rounded-full text-sm font-medium hover:bg-rose-primary/5 transition-colors disabled:opacity-50"
        >
          {{ paying ? '查詢中...' : '重新查詢付款狀態' }}
        </button>
      </div>

      <div class="mt-6 pt-4 border-t border-dashed border-gray-200">
        <p class="text-xs text-text-muted mb-2">以下為開發測試按鈕，不會經過綠界（debug）</p>
        <div class="flex gap-3">
          <button
            @click="handlePaySuccess"
            :disabled="paying"
            class="bg-sage text-white px-6 py-2 rounded-full text-xs font-medium hover:bg-sage/90 transition-colors disabled:opacity-50"
          >
            {{ paying ? '處理中...' : '付款成功 (debug)' }}
          </button>
          <button
            @click="handlePayFail"
            :disabled="paying"
            class="bg-red-500 text-white px-6 py-2 rounded-full text-xs font-medium hover:bg-red-600 transition-colors disabled:opacity-50"
          >
            {{ paying ? '處理中...' : '付款失敗 (debug)' }}
          </button>
        </div>
      </div>
    </div>
  </template>
</div>
